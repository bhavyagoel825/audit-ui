{
  "name": "audit-ui",
  "version": "0.1.0",
  "description": "Local spreadsheet audit and export desktop app",
  "author": "Spreadsheet Audit Tool",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "electron": "electron electron/main.cjs",
    "electron:dev": "ELECTRON_START_URL=http://localhost:3001 electron electron/main.cjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --arm64"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.0.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.9"
  },
  "build": {
    "appId": "com.local.spreadsheet-audit-tool",
    "productName": "Spreadsheet Audit Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Spreadsheet-Audit-Tool-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
